{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/patient/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/patient",
      "destination": "/app.html"
    },
    {
      "source": "/doctor/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/doctor",
      "destination": "/app.html"
    },
    {
      "source": "/zklogin/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/zklogin",
      "destination": "/app.html"
    }
  ]
}
