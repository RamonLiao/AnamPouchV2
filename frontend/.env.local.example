VITE_PORTABLE_HEALTH_PACKAGE_ID=0x0
VITE_SUI_NETWORK=testnet
# Optional override. Defaults to prover-dev on devnet, prover on testnet/mainnet.
VITE_ZKLOGIN_PROVER_URL=
# Optional frontend endpoint. Defaults to same-origin Vercel function.
VITE_ZKLOGIN_ZKP_ENDPOINT=/api/zklogin/zkp
# Preferred Google OAuth client id for zkLogin. Production prover only accepts
# allowlisted audiences; custom clients may need VITE_ZKLOGIN_PROVER_URL too.
VITE_ZKLOGIN_GOOGLE_CLIENT_ID=
# Server-only Vercel env var. Do not prefix with VITE_.
ENOKI_API_KEY=
VITE_SEAL_KEYSERVER_URL=
VITE_WALRUS_PUBLISHER_URL=
VITE_WALRUS_AGGREGATOR_URL=
